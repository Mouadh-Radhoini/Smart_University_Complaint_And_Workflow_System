{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
    <main style="max-width: 480px; margin: 60px auto; padding: 0 20px; font-family: Arial, sans-serif;">
        <h1 style="margin-bottom: 16px;">Student Registration</h1>

        {{ form_errors(registrationForm) }}

        {{ form_start(registrationForm) }}
            {{ form_row(registrationForm.fullName, { label: 'Full Name' }) }}
            {{ form_row(registrationForm.email, { label: 'Email' }) }}
            {{ form_row(registrationForm.plainPassword, { label: 'Password' }) }}

            <button type="submit" style="padding: 8px 14px;">Create account</button>
        {{ form_end(registrationForm) }}
    </main>
{% endblock %}
