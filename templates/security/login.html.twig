{% extends 'base.html.twig' %}

{% block title %}Login{% endblock %}

{% block body %}
    <main style="max-width: 420px; margin: 60px auto; padding: 0 20px; font-family: Arial, sans-serif;">
        <h1 style="margin-bottom: 16px;">Login</h1>

        {% if error %}
            <p style="color: #b00020; margin-bottom: 12px;">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </p>
        {% endif %}

        {% if app.user %}
            <p style="margin-bottom: 12px;">
                You are logged in as {{ app.user.userIdentifier }}.
                <a href="{{ logout_path() }}">Logout</a>
            </p>
        {% endif %}

        <form method="post">
            <label for="inputEmail">Email</label><br>
            <input type="email" value="{{ last_username }}" name="email" id="inputEmail" autocomplete="email" required autofocus style="width: 100%; margin: 6px 0 12px 0; padding: 8px;">

            <label for="inputPassword">Password</label><br>
            <input type="password" name="password" id="inputPassword" autocomplete="current-password" required style="width: 100%; margin: 6px 0 12px 0; padding: 8px;">

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" style="padding: 8px 14px;">Sign in</button>
        </form>
    </main>
{% endblock %}
